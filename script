(async function () {
  const GITHUB_TOKEN = "PASTE_TOKEN_MOI_VAO_DAY";
  const OWNER = "vusown";
  const REPO = "Nh-t-ki-m-b-thi-n";

  async function gh(url, options = {}) {
    const res = await fetch(url, {
      ...options,
      headers: {
        Authorization: `Bearer ${GITHUB_TOKEN}`,
        Accept: "application/vnd.github+json",
        "Content-Type": "application/json",
        ...(options.headers || {})
      }
    });

    const data = await res.json().catch(() => null);

    if (!res.ok) {
      console.error("GitHub API error:", res.status, data);
      throw new Error(`${res.status}: ${data?.message || "GitHub API error"}`);
    }

    return data;
  }

  function b64(str) {
    return btoa(unescape(encodeURIComponent(str)));
  }

  async function getDefaultBranch() {
    const repo = await gh(`https://api.github.com/repos/${OWNER}/${REPO}`);
    console.log("Default branch:", repo.default_branch);
    return repo.default_branch;
  }

  async function uploadFile(path, content, branch) {
    const url = `https://api.github.com/repos/${OWNER}/${REPO}/contents/${path}`;

    const data = await gh(url, {
      method: "PUT",
      body: JSON.stringify({
        message: `Upload ${path}`,
        content: b64(content),
        branch
      })
    });

    console.log("Uploaded:", data.content.html_url);
    return data.content.html_url;
  }

  const branch = await getDefaultBranch();

  // Test upload file nhỏ trước
  await uploadFile(
    `test-upload-${Date.now()}.txt`,
    "GitHub upload test OK",
    branch
  );

  alert("Upload test OK. Repo/token/branch dùng được.");
})();
